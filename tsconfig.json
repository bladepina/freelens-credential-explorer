{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "paths": {
      "@common/*": [
        "src/common/*"
      ],
      "@renderer/*": [
        "src/renderer/*"
      ]
    }
  },
  "include": [
    "src",
    "electron.vite.config.ts"
  ]
}
